<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
      <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
            <TextBlock Text="Toast Notification Demo" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
            
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Notification Title:" VerticalAlignment="Center" Width="120"/>
                <TextBox x:Name="TitleTextBox" Width="250" Text="Notification Title" Margin="5"/>
            </StackPanel>
            
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="Notification Message:" VerticalAlignment="Center" Width="120"/>
                <TextBox x:Name="MessageTextBox" Width="250" Text="This is a sample notification message." Margin="5"/>
            </StackPanel>
            
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="Notification Type:" VerticalAlignment="Center" Width="120"/>
                <ComboBox x:Name="NotificationTypeComboBox" Width="250" Margin="5">
                    <ComboBoxItem Content="Information" IsSelected="True"/>
                    <ComboBoxItem Content="Success"/>
                    <ComboBoxItem Content="Warning"/>
                    <ComboBoxItem Content="Error"/>
                </ComboBox>
            </StackPanel>
            
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="Duration (seconds):" VerticalAlignment="Center" Width="120"/>
                <Slider x:Name="DurationSlider" Minimum="1" Maximum="10" Value="3" Width="200" Margin="5"
                        IsSnapToTickEnabled="True" TickFrequency="1"/>
                <TextBlock Text="{Binding ElementName=DurationSlider, Path=Value, StringFormat='{}{0:0}'}" VerticalAlignment="Center" Margin="5,0,0,0"/>
            </StackPanel>
            
            <Button Content="Show Notification" Padding="15,5" Click="ShowNotification_Click"/>
        </StackPanel>
    </Grid>
</Window>
